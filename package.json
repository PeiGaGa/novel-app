{
  "name": "novel-reader",
  "version": "0.1.6",
  "description": "Desktop TXT novel reader with text-to-speech for Windows and macOS.",
  "productName": "小说朗读器",
  "author": "Codex",
  "license": "MIT",
  "main": "dist-electron/electron/main/index.js",
  "scripts": {
    "dev": "npm run build:main && concurrently -k \"vite --host 127.0.0.1\" \"tsc -p tsconfig.main.json --watch --preserveWatchOutput\" \"wait-on http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "typecheck": "vue-tsc --noEmit && tsc -p tsconfig.main.json --noEmit",
    "build": "npm run typecheck && npm run build:renderer && npm run build:main",
    "dist:installer": "npm run build && electron-builder --win nsis",
    "dist:portable": "npm run build && electron-builder --win portable",
    "dist:win": "npm run build && electron-builder --win nsis portable",
    "dist:mac": "npm run build && npm run dist:mac:x64 && npm run dist:mac:arm64",
    "dist:mac:x64": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dmg zip --x64 --publish never",
    "dist:mac:arm64": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dmg zip --arm64 --publish never"
  },
  "dependencies": {
    "cheerio": "1.0.0-rc.12",
    "iconv-lite": "^0.6.3",
    "jschardet": "^3.0.0",
    "lucide-vue-next": "^0.468.0",
    "pinia": "^2.1.7",
    "sql.js": "^1.10.3",
    "vue": "^3.4.21"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@vitejs/plugin-vue": "^4.6.2",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^25.9.8",
    "electron-builder": "^24.13.3",
    "typescript": "5.4.5",
    "vite": "^4.5.2",
    "vue-tsc": "^1.8.27",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.codex.novelreader",
    "productName": "小说朗读器",
    "copyright": "Copyright © 2026",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/sql.js/dist/sql-wasm.wasm"
    ],
    "npmRebuild": false,
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "category": "public.app-category.books",
      "identity": null,
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "dmg": {
      "title": "NovelReader-${version}-${arch}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "小说朗读器"
    },
    "artifactName": "${productName}-${version}-setup.${ext}",
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}"
    }
  },
  "allowScripts": {
    "electron": true,
    "electron@25.9.8": true,
    "esbuild": true,
    "esbuild@0.18.20": true,
    "vue-demi": true,
    "vue-demi@0.14.10": true
  }
}
